{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sakurasoft.local/schemas/brand.schema.json",
  "title": "Brand",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "label", "status"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^brand\\.[a-z0-9_]+(\\.[a-z0-9_]+)*$"
    },
    "label": { "type": "string", "minLength": 1 },
    "status": {
      "$ref": "common.json#/$defs/Status"
    },
    "aliases": {
      "type": "array",
      "items": { "type": "string" }
    },
    "tags": {
      "type": "array",
      "items": { "type": "string" }
    },
    "notes": { "type": "string" },
    "style": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "aesthetic": { "type": "string" },
        "audience": { "type": "string" },
        "palette": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        }
      }
    },
    "docs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["path"],
        "additionalProperties": false,
        "properties": {
          "path": { "type": "string" },
          "label": { "type": "string" }
        }
      }
    }
  }
}

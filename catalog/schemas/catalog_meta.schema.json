{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sakurasoft.local/schemas/catalog_meta.schema.json",
  "title": "Catalog meta",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "studio", "default_locale"],
  "properties": {
    "schema_version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "studio": { "type": "string", "minLength": 1 },
    "default_locale": { "type": "string", "minLength": 2 },
    "locales": {
      "type": "array",
      "items": { "type": "string", "minLength": 2 },
      "uniqueItems": true
    },
    "path_conventions": {
      "type": "object",
      "additionalProperties": { "type": "string" }
    },
    "id_prefixes": {
      "type": "object",
      "additionalProperties": { "type": "string" }
    }
  }
}
